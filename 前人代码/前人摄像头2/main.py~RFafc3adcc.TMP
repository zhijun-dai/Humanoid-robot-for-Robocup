import sensor, image, time
from pyb import LED,UART
LED(1).on()
LED(2).on()
LED(3).on()
sensor.reset()
sensor.set_pixformat(sensor.GRAYSCALE)
sensor.set_framesize(sensor.QVGA)
sensor.skip_frames(time = 2000)
clock = time.clock()
left_flag = 0
right_flag = 0
flag = 0
uart = UART(1,9600)
QR_uart = UART(3,9600)
QR_result = '4'
QR_detect = ''
start_time = time.time()
right_flag = 0
flag1 = 0
theLast = ''
i = 0
zhaidao_flag = 0
while(True):
	clock.tick()
	end_time = time.time()
	print(abs(end_time - start_time))
	if abs(end_time - start_time) >= 90:
		zhaidao_flag = 1
	if QR_uart.any():
		a = QR_uart.readline()
		if a == b'1\r':
			QR_result = '4'
		elif a == b'2\r':
			QR_result = '5'
		elif a == b'3\r':
			QR_result = '6'
		elif a == b'4\r':
			QR_result = '7'
		elif a == b'5\r':
			QR_result = '8'
		elif a == b'6\r':
			QR_result = '9'
		if not QR_result == QR_detect:
			uart.write(QR_result)
			print(QR_result)
			QR_detect = QR_result
			time.sleep_ms(4000)
			uart.write(QR_result)
	img = sensor.snapshot().lens_corr(1.5)
	line = img.get_regression([(0, 35)], robust = True,roi=(0,85,118,112),pixel_threshold=600)
	line2 = img.get_regression([(0, 35)], robust = True,roi=(207,49,105,133),pixel_threshold=800)
	img.draw_rectangle((0,85,118,112),thickness = 2, fill = False)
	img.draw_rectangle((207,49,105,133),thickness = 2, fill = False)
	if zhaidao_flag == 0:
		if (line) or (line2):
			img.draw_line(line.line(), color=127) if line else None
			img.draw_line(line2.line(), color=127) if line2 else None
			if (line) and (line2):
				uart.write('1')
				uart_read = uart.readline()
				if uart_read:
					print("直走")
					print("uart_read:",uart_read)
			elif (line) and not (line2):
				right_start_time = time.time()
				uart.write('3')
				uart_read = uart.readline()
				if uart_read:
					print("右转")
					print("uart_read:",uart_read)
			elif not (line) and (line2):
				left_start_time = time.time()
				uart.write('2')
				uart_read = uart.readline()
				if uart_read:
					print("左转")
					print("uart_read:",uart_read)
		else:
			uart.write('3')
			uart_read = uart.readline()
			if uart_read:
				print("右转")
				print("uart_read:",uart_read)
	elif zhaidao_flag == 1:
		if (line) or (line2):
			img.draw_line(line.line(), color=127) if line else None
			img.draw_line(line2.line(), color=127) if line2 else None
			if (line) and (line2):
				uart.write('0')
				uart_read = uart.readline()
				if uart_read:
					print("直走")
					print("uart_read:",uart_read)
			elif (line) and not (line2):
				right_start_time = time.time()
				uart.write('3')
				uart_read = uart.readline()
				if uart_read:
					print("右转")
					print("uart_read:",uart_read)
			elif not (line) and (line2):
				left_start_time = time.time()
				uart.write('2')
				uart_read = uart.readline()
				if uart_read:
					print("左转")
					print("uart_read:",uart_read)
		else:
			uart.write('3')
			uart_read = uart.readline()
			if uart_read:
				print("右转")
				print("uart_read:",uart_read)